# Typical gitignore for Node.js and basic web projects
# repo-policy: ignore patterns here are intentional; do not autonomously modify exclusion rules
# governance-note: ai agents must not alter .gitignore to expose protected or excluded paths

# Dependencies
node_modules/
backend/node_modules/

# Environment variables
.env
backend/.env
.myenv

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS files
.DS_Store
Thumbs.db

# IDEs
.vscode/
.idea/
*.swp
*.swo

# Temporary files
tmp/
temp/

# Backend (not needed for static deployment)
backend/

# PowerShell scripts
*.ps1
